{
  "title": "Affiliation",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "affiliationIdentifier": {
      "type": ["string", "null"]
    },
    "affiliationIdentifierScheme": {
      "type": ["string", "null"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "schemeUri": {
      "type": ["string", "null"]
    }
  },
  "required": ["name"],
  "additionalProperties": false
}