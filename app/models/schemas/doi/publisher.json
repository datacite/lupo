{
  "title": "Publisher",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The name of the entity that holds, archives, publishes prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.",
  "type": "object",
  "properties": {
    "name": {
      "$ref": "definitions.json#/$defs/nonemptycontentStringType"
    },
    "publisherIdentifier": { 
      "type": [ "string", "null" ]
    },
    "publisherIdentifierScheme": {
       "type": [ "string", "null" ]
    },
    "schemeUri": { 
      "type": [ "string", "null" ] 
    },
    "lang": {
      "oneOf": [
        {
          "$ref": "definitions.json#/$defs/language"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "name"
  ]
}
