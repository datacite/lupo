{
  "title": "FundingReference",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Information about financial support (funding) for the resource being registered.",
  "type": "object",
  "properties": {
    "funderName": {
      "$ref": "definitions.json#/$defs/nonemptycontentStringType"
    },
    "funderIdentifier": {
      "type": ["string", "null"]
    },
    "funderIdentifierType": {
      "oneOf": [
        {
          "$ref": "controlled_vocabularies/funder_identifier_type.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "schemeUri": {
      "type": ["string", "null"],
       "format": "uri"
    },
    "awardNumber": {
      "type": ["string", "null"]
    },
    "awardUri": {
      "type": ["string", "null"]
    },
    "awardTitle": {
      "type": ["string", "null"]
    }
  },
  "required": [
    "funderName"
  ],
  "additionalProperties": false
}
