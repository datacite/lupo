{
  "title": "NameIdentifier",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Uniquely identifies a creator or contributor, according to various identifier schemes.",
  "type": "object",
  "properties": {
    "nameIdentifier": {
      "$ref": "definitions.json#/$defs/nonemptycontentStringType"
    },
    "nameIdentifierScheme": {
      "type": "string"
    },
    "schemeUri": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false,
  "required": [
    "nameIdentifier",
    "nameIdentifierScheme"
  ]
}
