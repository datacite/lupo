{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "definitions.json",
  "Description": "Definitions for re-use in the DOI metadata schema.",
	"$defs": {
    "nonemptycontentStringType": {
      "minLength": 1,
      "type": "string"
    },
    "edtf": {
			"type": "string",
			"anyOf": [
				{ "pattern": "(-)?[0-9]{4}(-[0-9]{2})?(-[0-9]{2})?(T([0-9]{2}:){2}[0-9]{2}Z)?" },
				{ "pattern": "\\d{2}(\\d{2}|\\?\\?|\\d(\\d|\\?))(-(\\d{2}|\\?\\?))?~?\\??" },
				{ "pattern": "\\d{6}(\\d{2}|\\?\\?)?~?\\??" },
				{ "pattern": "\\d{8}T\\d{6}" },
				{ "pattern": "((-)?(\\d{4}(-\\d{2})?(-\\d{2})?)|unknown)/((-)?(\\d{4}(-\\d{2})?(-\\d{2})?)|unknown|open)" }
			]
    },
    "yearType": {
			"type": [ "integer", "string" ],
			"oneOf": [
				{
					"pattern": "[\\d]{4}",
					"type": "string"
				},
				{
					"type": "integer",
					"minimum": 1000,
					"maximum": 9999
				}
			]
    },
    "longitudeType": {
      "maximum": 180,
      "minimum": -180,
      "type": "number"
    },
    "latitudeType": {
      "maximum": 90,
      "minimum": -90,
      "type": "number"
    },
		"box": {
			"type": "object",
			"properties": {
				"westBoundLongitude": {
					"$ref": "#/$defs/longitudeType"
				},
				"eastBoundLongitude": {
					"$ref": "#/$defs/longitudeType"
				},
				"southBoundLatitude": {
					"$ref": "#/$defs/latitudeType"
				},
				"northBoundLatitude": {
					"$ref": "#/$defs/latitudeType"
				}
			},
			"required": [
				"westBoundLongitude",
				"eastBoundLongitude",
				"southBoundLatitude",
				"northBoundLatitude"
			],
			"additionalProperties": false
    },
		"point": {
			"type": "object",
			"properties": {
				"pointLongitude": {
					"$ref": "#/$defs/longitudeType"
				},
				"pointLatitude": {
					"$ref": "#/$defs/latitudeType"
				}
			},
			"required": [
				"pointLongitude",
				"pointLatitude"
			],
			"additionalProperties": false
		},
		"language": {
			"type": [ "string", "null" ],
			"pattern": "^[a-zA-Z]{1,8}(-[a-zA-Z0-9]{1,8})*$"
		}
	}
}
